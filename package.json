{
  "name": "bifan-webar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "BIFAN 30th anniversary WebAR experience",
  "scripts": {
    "sync:xr": "node scripts/sync-xr-assets.mjs",
    "dev": "npm run sync:xr && vite --port 5181",
    "dev:full": "npm run sync:xr && sh -c 'set -a; . ./.env.local; set +a; npx --yes vercel@54.14.5 dev --listen 127.0.0.1:5181'",
    "dev:https": "npm run sync:xr && BIFAN_HTTPS=1 vite --host 0.0.0.0 --port 5181",
    "tunnel": "cloudflared tunnel --url https://localhost:5181 --no-tls-verify",
    "build": "npm run sync:xr && tsc && vite build",
    "preview": "vite preview",
    "test": "npm run test:unit && npm run test:ui",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:ui": "playwright test"
  },
  "dependencies": {
    "@8thwall/engine-binary": "^1.0.0",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/three": "0.184.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
